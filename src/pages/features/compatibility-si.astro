---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import PorondamTool from '../../components/islands/PorondamTool.jsx';
import content from '../../partials/features/compatibility-si.html?raw';
const jsonld = '{"@context":"https://schema.org","@type":"WebPage","name":"පොරොන්දම් ගැළපීම — ග්‍රහචාර","url":"https://grahachara.com/features/compatibility-si","inLanguage":"si","isPartOf":{"@type":"WebSite","name":"Grahachara","url":"https://grahachara.com"}}';
---
<ArticleLayout
  lang="si"
  title="පොරොන්දම් ගැළපීම — ග්‍රහචාර | විවාහ පොරොන්දම් සහ නැකත"
  description="ග්‍රහචාර යෙදුමෙන් ඔබේ පොරොන්දම් නිවැරදිව ගණනය කරගන්න. නාඩි, ගණ, භකූට ඇතුළු පොරොන්දම් 20, දෝෂ පිළියම් සහ සුබ විවාහ නැකත් — නක්ෂත්‍ර පදනම්ව."
  canonical="https://grahachara.com/features/compatibility-si"
  eyebrow="විශේෂාංගය"
  heroTitle="පොරොන්දම් ගැළපීම"
  heroSub="ඔබේ විශ්වීය බැඳීම සොයාගන්න. පැරණි පොරොන්දම් ක්‍රමය ඔබේ තරු ගැළපෙනවාද යන්න හෙළි කරයි — ආදරයට, විවාහයට සහ හවුල්කාරිත්වයට."
  breadcrumb={[{"label":"මුල් පිටුව","href":"../si.html"},{"label":"විශේෂාංග","href":"../si.html#explore"},{"label":"පොරොන්දම්"}]}
  bg="page_hero_porondam.webp"
  active="පොරොන්දම්"
  jsonld={jsonld}
>
  <section class="pc-toolband" slot="tool">
    <div class="pc-wrap">
      <div class="pc-section__head">
        <div class="pc-flourish" style="max-width:320px;margin:0 auto 14px;">නොමිලේ අත්හදා බලන්න</div>
        <h2 class="pc-section__title pc-gold-text">ඔබේ පොරොන්දම් බලන්න</h2>
        <p class="pc-section__sub">ඔබේ මුල් පොරොන්දම් තුන නොමිලේ බලන්න — ඉන්පසු සම්පූර්ණ පොරොන්දම් 20 සහ සුබ විවාහ නැකත් යෙදුමෙන් අගුළු හරින්න.</p>
      </div>
      <PorondamTool client:visible lang="si" />
    </div>
  </section>
  <Fragment set:html={content} />
</ArticleLayout>
