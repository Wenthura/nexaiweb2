---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const a = (p) => `${base}/assets/cosmos/${p}`;
const V = '3'; // asset cache-bust version
const bust = (u) => `${u}?v=${V}`;
---
<div class="pc-loader" id="pcLoader" role="status" aria-label="Loading Grahachara" data-base={base}>
  <img class="pc-loader__neb" src={bust(a('hero_nebula.webp'))} alt="" aria-hidden="true" data-depth="5" />
  <div class="pc-loader__stars" aria-hidden="true" data-depth="3"></div>
  <div class="pc-loader__planet pc-loader__planet--j" aria-hidden="true" data-depth="22"><img src={bust(a('planet_jupiter.webp'))} alt="" width="768" height="768" /></div>
  <div class="pc-loader__planet pc-loader__planet--m" aria-hidden="true" data-depth="30"><img src={bust(`${base}/assets/cosmos/moon.webp`)} alt="" width="512" height="512" /></div>

  <div class="pc-loader__core" id="pcLoaderCore" data-depth="9">
    <span class="pc-loader__halo" aria-hidden="true" data-depth="-26"></span>
    <img class="pc-loader__portal" src={bust(a('loader_portal.webp'))} alt="" aria-hidden="true" />
    <img class="pc-loader__logo" src={bust(`${base}/assets/logo.png`)} alt="Grahachara" width="120" height="120" />
  </div>

  <div class="pc-loader__brand">
    <span class="pc-loader__name">GRAHACHARA</span>
    <span class="pc-loader__tag">Reading the stars…</span>
    <span class="pc-loader__bar"><i></i></span>
  </div>
</div>

<script is:inline>
  (function () {
    var el = document.getElementById('pcLoader');
    if (!el) return;
    var reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    var base = el.getAttribute('data-base') || '';
    var V = '3';
    var start = Date.now(), MIN = 3000, CAP = 15000, done = false; // 3s min; wait for assets; hard cap
    document.documentElement.style.overflow = 'hidden';

    function finish() {
      if (done) return; done = true;
      el.classList.add('is-done');
      document.documentElement.style.overflow = '';
      setTimeout(function () { if (el && el.parentNode) el.parentNode.removeChild(el); }, 1000);
    }
    function whenReady() { setTimeout(finish, Math.max(0, MIN - (Date.now() - start))); }
    setTimeout(finish, CAP);

    // Preload every above-the-fold asset so nothing pops in when the site is revealed.
    var critical = [
      'hero_nebula.webp', 'hero_nebula_normal.webp', 'hero_nebula_roughness.webp', 'hero_nebula_height.webp',
      'moon.webp', 'planet_jupiter.webp', 'planet_saturn.webp', 'planet_mars.webp',
      'cloud_front.webp', 'cloud_mid.webp', 'zodiac_wheel.webp', 'loader_portal.webp'
    ].map(function (f) { return base + '/assets/cosmos/' + f + '?v=' + V; });
    critical.push(base + '/assets/logo.png?v=' + V);
    critical.push(base + '/assets/cosmos/logo_emblem.png?v=' + V);

    var pending = critical.length + 1; // + the window 'load' event
    function tick() { if (--pending <= 0) whenReady(); }
    critical.forEach(function (u) { var im = new Image(); im.onload = tick; im.onerror = tick; im.src = u; });
    if (document.readyState === 'complete') tick(); else window.addEventListener('load', tick);

    // Parallax — cursor on desktop, calibrated device tilt (via __gcTilt) on phones.
    // The halo has a negative depth (light counter-moves) and the mandala core
    // additionally tilts in 3D like a coin catching the light.
    if (!reduce) {
      var layers = el.querySelectorAll('[data-depth]'), core = document.getElementById('pcLoaderCore');
      var raf = null, tx = 0, ty = 0;
      function apply() {
        raf = null;
        for (var i = 0; i < layers.length; i++) {
          var d = parseFloat(layers[i].getAttribute('data-depth')) || 0;
          layers[i].style.translate = (-tx * d).toFixed(1) + 'px ' + (-ty * d).toFixed(1) + 'px';
        }
        if (core) core.style.transform = 'perspective(700px) rotateY(' + (tx * 10).toFixed(2) + 'deg) rotateX(' + (-ty * 10).toFixed(2) + 'deg)';
      }
      function set(x, y) { tx = x; ty = y; if (!raf) raf = requestAnimationFrame(apply); }
      el.addEventListener('mousemove', function (e) { set(e.clientX / innerWidth - 0.5, e.clientY / innerHeight - 0.5); }, { passive: true });
      if (window.__gcTilt) window.__gcTilt.on(function (x, y) { set(x, y); });
    }
  })();
</script>
