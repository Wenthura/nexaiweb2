---
import '../styles/styles.css';
import '../styles/portal.css';
import Loader from '../components/Loader.astro';

const {
  title = 'Grahachara — Best Vedic Astrology App | Birth Chart, Horoscope & Life Predictions',
  description = 'Grahachara is the #1 Vedic astrology app using NASA-grade calculations. Get your personalized birth chart (Kundali), Nakshatra analysis, compatibility matching, 25-year life predictions & daily horoscope. Available worldwide.',
  lang = 'en',
  canonical = 'https://grahachara.com/',
  ogTitle = 'Grahachara — Your Destiny, Decoded',
  ogDescription = 'Vedic astrology, deeply personal. Birth chart analysis, compatibility matching, life reports & daily cosmic guidance.',
  bodyClass = '',
  keywords = '',
  altEn = '',        // English-language alternate of this page (defaults to canonical when lang=en)
  altSi = '',        // Sinhala-language alternate of this page, if one exists
} = Astro.props;

const enUrl = altEn || (lang === 'en' ? canonical : '');
const siUrl = altSi || (lang === 'si' ? canonical : '');
const ogLocale = lang === 'si' ? 'si_LK' : 'en_US';
const ogLocaleAlt = lang === 'si' ? 'en_US' : 'si_LK';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang={lang} dir="ltr" prefix="og: https://ogp.me/ns#">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

  <title>{title}</title>
  <meta name="description" content={description} />
  {keywords && <meta name="keywords" content={keywords} />}
  <meta name="author" content="Wenthura Solutions Pvt Ltd" />
  <meta name="theme-color" content="#05060f" />
  <meta name="color-scheme" content="dark" />
  <meta name="application-name" content="Grahachara" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="Grahachara" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

  <link rel="canonical" href={canonical} />
  {enUrl && <link rel="alternate" hreflang="en" href={enUrl} />}
  {siUrl && <link rel="alternate" hreflang="si" href={siUrl} />}
  {siUrl && <link rel="alternate" hreflang="si-LK" href={siUrl} />}
  <link rel="alternate" hreflang="x-default" href={enUrl || canonical} />
  <meta name="google-site-verification" content="4c698284df612df3" />

  <meta property="og:site_name" content="Grahachara" />
  <meta property="og:title" content={ogTitle} />
  <meta property="og:description" content={ogDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content={ogLocale} />
  <meta property="og:locale:alternate" content={ogLocaleAlt} />
  <meta property="og:image" content="https://grahachara.com/assets/og-card.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle} />
  <meta name="twitter:description" content={ogDescription} />
  <meta name="twitter:image" content="https://grahachara.com/assets/og-card.png" />

  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
  <link rel="manifest" href={`${base}/manifest.json`} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
  <link href="https://api.fontshare.com/v2/css?f[]=clash-display@200,300,400,500,600,700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />

  <link rel="icon" type="image/png" sizes="192x192" href={`${base}/assets/android-chrome-192x192.png?v=3`} />
  <link rel="icon" type="image/png" sizes="32x32" href={`${base}/assets/favicon-32x32.png?v=3`} />
  <link rel="icon" type="image/png" sizes="16x16" href={`${base}/assets/favicon-16x16.png?v=3`} />
  <link rel="icon" type="image/x-icon" href={`${base}/assets/favicon.ico?v=3`} />
  <link rel="apple-touch-icon" sizes="180x180" href={`${base}/assets/apple-touch-icon.png?v=3`} />

  <slot name="head" />
</head>
<body class={bodyClass}>
  <script is:inline>
    /* iOS 13+ needs a user gesture to unlock the gyroscope; grant it on first touch
       so the hero/loader depth layers respond to phone flip & turn. */
    (function () {
      var D = window.DeviceOrientationEvent;
      if (!D || typeof D.requestPermission !== 'function') return;
      function ask() {
        document.removeEventListener('touchend', ask);
        try { D.requestPermission().catch(function () {}); } catch (e) {}
      }
      document.addEventListener('touchend', ask, { once: true, passive: true });
    })();
  </script>
  <script is:inline>
    /* ── Grahachara tilt engine (window.__gcTilt) ─────────────────────────
       Turns raw gyroscope angles into a "magic window" signal:
       • Calibrates to however the phone rests in the hand — the first readings
         become the neutral pose, and the baseline slowly re-centres (~5s), so
         lying in bed, standing, or flat on a desk all feel identical.
       • Tiny deflections respond immediately (±18° = full swing).
       • A spring-smoothed rAF loop gives weight and glide instead of jitter.
       Subscribers: window.__gcTilt.on(fn(x, y)) with x,y in [-1, 1].          */
    (function () {
      if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      var baseB = null, baseG = null, tgX = 0, tgY = 0, x = 0, y = 0;
      var subs = [], api = { x: 0, y: 0, active: false, on: function (f) { subs.push(f); } };
      window.__gcTilt = api;
      window.addEventListener('deviceorientation', function (e) {
        if (e.beta == null || e.gamma == null) return;
        var b = e.beta, g = e.gamma;
        // portrait-flip guard: keep gamma continuous when the phone passes vertical
        if (baseB === null) { baseB = b; baseG = g; }
        baseB += (b - baseB) * 0.006;   // slow re-centre → resting pose is always neutral
        baseG += (g - baseG) * 0.006;
        tgX = Math.max(-1, Math.min(1, (g - baseG) / 18));
        tgY = Math.max(-1, Math.min(1, (b - baseB) / 18));
        api.active = true;
      }, { passive: true });
      function tick() {
        x += (tgX - x) * 0.085; y += (tgY - y) * 0.085;   // inertial glide
        api.x = x; api.y = y;
        if (api.active) for (var i = 0; i < subs.length; i++) subs[i](x, y);
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    })();
  </script>
  <Loader />
  <script is:inline>
    /* Language preference + auto-Sinhala for Sri Lankan visitors (home only). */
    (function () {
      try {
        var KEY = 'gc-lang';
        var pref = null; try { pref = localStorage.getItem(KEY); } catch (e) {}
        var p = location.pathname;
        var onSi = /\/si\.html$/.test(p);
        var onEnHome = /\/$/.test(p) || /\/index\.html$/.test(p);
        if (pref === 'si' && onEnHome) { location.replace('si.html'); return; }
        if (pref === 'en' && onSi) { location.replace('index.html'); return; }
        if (!pref && onEnHome) {
          var ls = (navigator.languages && navigator.languages.length) ? navigator.languages : [navigator.language || ''];
          var wantsSi = ls.some(function (l) { return /^si\b/i.test(l); });
          var tz = ''; try { tz = Intl.DateTimeFormat().resolvedOptions().timeZone || ''; } catch (e) {}
          if (wantsSi || tz === 'Asia/Colombo') { location.replace('si.html'); return; }
        }
      } catch (e) {}
      /* Remember the visitor's explicit choice when they use the toggle. */
      document.addEventListener('click', function (e) {
        var a = e.target.closest && e.target.closest('[data-lang]');
        if (a) { try { localStorage.setItem('gc-lang', a.getAttribute('data-lang')); } catch (_) {} }
      }, true);
    })();
  </script>
  <slot />
</body>
</html>
