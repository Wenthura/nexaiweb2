---
// SEO FAQ block — visible <details> accordion + FAQPage JSON-LD (Google rich results).
const { title, sub = '', items = [], eyebrow = 'FAQ' } = Astro.props;
const jsonld = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((it) => ({
    '@type': 'Question',
    name: it.q,
    acceptedAnswer: { '@type': 'Answer', text: it.a },
  })),
});
---
<section class="pc-section pc-faq" id="faq">
  <div class="pc-wrap">
    <div class="pc-section__head">
      <div class="pc-flourish" style="max-width:260px;margin:0 auto 14px;">{eyebrow}</div>
      <h2 class="pc-section__title pc-gold-text">{title}</h2>
      {sub && <p class="pc-section__sub">{sub}</p>}
    </div>
    <div class="pc-faq__list">
      {items.map((it) => (
        <details class="pc-faq__item">
          <summary>
            <span>{it.q}</span>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 9l6 6 6-6" /></svg>
          </summary>
          <p set:html={it.a}></p>
        </details>
      ))}
    </div>
  </div>
</section>
<script type="application/ld+json" is:inline set:html={jsonld} />
