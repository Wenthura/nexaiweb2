---
import { PLAY_URL } from '../data/site.js';
const { lang = 'en' } = Astro.props;
const si = lang === 'si';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const T = si ? {
  statement: 'තරු අතර ලියා ඇත.<br />ඔබේ දුරකථනයෙන් කියවන්න.',
  tagline: 'වේද ජ්‍යොතිෂය, ගැඹුරින් පෞද්ගලික — ඔබේ නිශ්චිත උපන් වේලාවට හා ස්ථානයට ගැළපේ.',
  dl: 'Google Play වෙතින් ලබාගන්න',
  getApp: 'යෙදුම ලබාගන්න', altLangLabel: 'English', altLangHref: `${base}/index.html`,
  saying: 'සෑම තැනකම, එකම අහස යට කියවන්න.',
} : {
  statement: 'Written in the stars.<br />Read on your phone.',
  tagline: 'Vedic astrology, deeply personal — tuned to your exact birth time and place.',
  dl: 'Get it on Google Play',
  getApp: 'Get the App', altLangLabel: 'සිංහල', altLangHref: `${base}/si.html`,
  saying: 'Read beneath the same sky, everywhere.',
};
const cols = si ? [
  { h: 'සොයන්න', links: [
    ['කේන්දරය', `${base}/features/birth-chart-si.html`],
    ['පොරොන්දම්', `${base}/features/compatibility-si.html`],
    ['දෛනික නැකත', `${base}/features/daily-horoscope.html`],
    ['ජීවිත වාර්තාව', `${base}/features/life-report.html`],
    ['රාශි', `${base}/features/zodiac-signs.html`],
  ] },
  { h: 'දැනගන්න', links: [
    ['වේද ජ්‍යොතිෂය යනු?', `${base}/blog/what-is-vedic-astrology.html`],
    ['වේද එදිරිව බටහිර', `${base}/blog/vedic-vs-western-astrology.html`],
    ['නක්ෂත්‍රය යනු?', `${base}/blog/what-is-nakshatra.html`],
  ] },
  { h: 'නීතිමය', links: [
    ['රහස්‍යතා ප්‍රතිපත්තිය', `${base}/legal/privacy.html`],
    ['සේවා කොන්දේසි', `${base}/legal/terms.html`],
    ['ආපසු ගෙවීම් ප්‍රතිපත්තිය', `${base}/legal/refund.html`],
  ] },
  { h: 'සහාය', links: [
    ['උදව් මධ්‍යස්ථානය', `${base}/legal/support.html`],
    ['සම්බන්ධ වන්න', `${base}/legal/contact.html`],
    ['ගිණුම මකන්න', `${base}/legal/delete-account.html`],
  ] },
] : [
  { h: 'Explore', links: [
    ['Birth Chart', `${base}/features/birth-chart.html`],
    ['Compatibility', `${base}/features/compatibility.html`],
    ['Daily Horoscope', `${base}/features/daily-horoscope.html`],
    ['Life Report', `${base}/features/life-report.html`],
    ['Zodiac Signs', `${base}/features/zodiac-signs.html`],
  ] },
  { h: 'Learn', links: [
    ['What Is Vedic Astrology?', `${base}/blog/what-is-vedic-astrology.html`],
    ['Vedic vs Western', `${base}/blog/vedic-vs-western-astrology.html`],
    ['What Is Nakshatra?', `${base}/blog/what-is-nakshatra.html`],
  ] },
  { h: 'Legal', links: [
    ['Privacy Policy', `${base}/legal/privacy.html`],
    ['Terms of Service', `${base}/legal/terms.html`],
    ['Refund Policy', `${base}/legal/refund.html`],
  ] },
  { h: 'Support', links: [
    ['Help Center', `${base}/legal/support.html`],
    ['Contact', `${base}/legal/contact.html`],
    ['Delete Account', `${base}/legal/delete-account.html`],
  ] },
];
---
<footer class="pc-footer">
  <div class="pc-footer__body">
    <img class="pc-footer__art pc-footer__art--temples" src={`${base}/assets/cosmos/footer_art.webp`} alt="" width="1792" height="1024" loading="lazy" aria-hidden="true" />
    <div class="pc-footer__veil" aria-hidden="true"></div>

  <div class="pc-wrap pc-footer__inner">
    <div class="pc-footer__cta">
      <img class="pc-footer__logo" src={`${base}/assets/logo.png`} alt="Grahachara" width="76" height="76" />
      <h2 class="pc-footer__statement" set:html={T.statement}></h2>
      <p class="pc-footer__tagline">{T.tagline}</p>
      <a class="pc-btn-gold pc-footer__dl" href={PLAY_URL} target="_blank" rel="noopener">{T.dl}</a>
      <div class="pc-footer__socials">
        <a href="https://www.facebook.com/share/1FBBur8QZf/" target="_blank" rel="noopener" aria-label="Facebook"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></a>
        <a href="https://www.instagram.com/grahachara_astro" target="_blank" rel="noopener" aria-label="Instagram"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg></a>
        <a href="https://www.tiktok.com/@grahachara_astro" target="_blank" rel="noopener" aria-label="TikTok"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg></a>
      </div>
    </div>

    <div class="pc-footer__grid">
      {cols.map((c) => (
        <div class="pc-footer__col">
          <h5 class="pc-footer__heading">{c.h}</h5>
          {c.links.map((l) => <a href={l[1]}>{l[0]}</a>)}
        </div>
      ))}
      <div class="pc-footer__col">
        <h5 class="pc-footer__heading">{T.getApp}</h5>
        <a href={PLAY_URL} target="_blank" rel="noopener">Google Play</a>
        <a href={T.altLangHref}>{T.altLangLabel}</a>
      </div>
    </div>

    <div class="pc-footer__bottom">
      <span>© 2026 Grahachara by Wenthura Solutions Pvt Ltd. All rights reserved.</span>
      <span class="pc-footer__saying">{T.saying}</span>
    </div>
  </div>
  </div>
</footer>
