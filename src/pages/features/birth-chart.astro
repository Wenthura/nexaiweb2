---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import KendaraTool from '../../components/islands/KendaraTool.jsx';
import content from '../../partials/features/birth-chart.html?raw';
const jsonld = "{\r\n    \"@context\": \"https://schema.org\",\r\n    \"@type\": \"WebPage\",\r\n    \"name\": \"Vedic Birth Chart Analysis — Grahachara\",\r\n    \"description\": \"Get your complete Vedic birth chart analyzed with NASA-grade planetary calculations.\",\r\n    \"url\": \"https://grahachara.com/features/birth-chart\",\r\n    \"isPartOf\": { \"@type\": \"WebSite\", \"name\": \"Grahachara\", \"url\": \"https://grahachara.com\" },\r\n    \"breadcrumb\": {\r\n      \"@type\": \"BreadcrumbList\",\r\n      \"itemListElement\": [\r\n        { \"@type\": \"ListItem\", \"position\": 1, \"name\": \"Home\", \"item\": \"https://grahachara.com/\" },\r\n        { \"@type\": \"ListItem\", \"position\": 2, \"name\": \"Features\", \"item\": \"https://grahachara.com/features/\" },\r\n        { \"@type\": \"ListItem\", \"position\": 3, \"name\": \"Birth Chart Analysis\" }\r\n      ]\r\n    }\r\n  }";
---
<ArticleLayout
  title="Vedic Birth Chart Analysis App — Grahachara | Accurate Jyotish Kundali"
  description="Get your complete Vedic birth chart (Kundali) analyzed with NASA-grade planetary calculations. All 12 houses, 27 Nakshatras, Dasha periods & planetary aspects — interpreted personally for you."
  canonical="https://grahachara.com/features/birth-chart"
  eyebrow="Feature"
  heroTitle="Vedic Birth Chart Analysis"
  heroSub="Your complete Kundali — calculated with NASA-grade precision, interpreted house by house. A map of your destiny written in the stars."
  breadcrumb={[{"label":"Home","href":"../index.html"},{"label":"Features","href":"../index.html#features"},{"label":"Birth Chart"}]}
  bg="page_hero_kendara.webp"
  active="Birth Chart"
  jsonld={jsonld}
>
  <section class="pc-toolband" slot="tool">
    <div class="pc-wrap">
      <div class="pc-section__head">
        <div class="pc-flourish" style="max-width:300px;margin:0 auto 14px;">Try It Free</div>
        <h2 class="pc-section__title pc-gold-text">Cast your Kendara now</h2>
        <p class="pc-section__sub">Enter your birth details for a real chart to keep and share — your full 25-year reading awaits in the app.</p>
      </div>
      <KendaraTool client:visible />
    </div>
  </section>
  <Fragment set:html={content} />
</ArticleLayout>
